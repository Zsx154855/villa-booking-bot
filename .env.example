# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Payment - Stripe
# Stripe测试密钥 (sk_test_xxx) - 用于开发测试
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
# Stripe公钥 (pk_test_xxx) - 用于前端
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Stripe Webhook签名密钥 - 在Stripe Dashboard获取
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe生产密钥 (切换到生产环境时使用)
# STRIPE_SECRET_KEY=sk_live_your_stripe_live_key
# STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_live_your_webhook_secret

# Database (optional - defaults to SQLite)
DATABASE_URL=postgresql://user:pass@host:port/db

# Server
PORT=8080

# Webhook URL (用于配置Stripe Webhook)
# WEBHOOK_URL=https://your-domain.com

# ============ LangGraph 配置 ============
# LangGraph多轮对话系统

# LLM提供者选择
LANGGRAPH_LLM_PROVIDER=deepseek

# DeepSeek配置
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# LangGraph检查点存储 (memory/redis/postgres)
LANGGRAPH_CHECKPOINTER=memory

# 最大对话步数限制
LANGGRAPH_MAX_STEPS=20
